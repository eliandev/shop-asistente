# ── Anthropic ────────────────────────────────────────────────────────────────
# Tu llave real: https://console.anthropic.com -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-tu-llave-aqui

# Opcional. Por defecto Haiku (rápido y económico). Alternativa: claude-sonnet-5
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Shopify — catálogo en vivo (opcional) ────────────────────────────────────
# Si configurás el dominio, Silvi consulta productos y precios EN VIVO desde tu
# tienda vía el UCP Catalog MCP (público, solo lectura, SIN token).
# Si lo dejás vacío, usa los productos de ejemplo de lib/knowledge-base.ts.
#
# Dominio de tu tienda (sirve el público, ej. mitienda.com, o el interno
# mitienda.myshopify.com):
SHOPIFY_STORE_DOMAIN=

# Opcional. URL del perfil UCP de tu agente (recomendado publicar uno propio
# para producción; por defecto se usa el perfil de ejemplo de shopify.dev):
UCP_AGENT_PROFILE=

# Opcional. RESPALDO por Storefront API (GraphQL): solo se usa si el UCP MCP
# falla Y este token está configurado. Podés dejarlo vacío.
SHOPIFY_STOREFRONT_TOKEN=
# Versión de la API del respaldo (por defecto 2026-04):
SHOPIFY_API_VERSION=2026-04

# ── Monetización — widget Pro ────────────────────────────────────────────────
# Secreto para firmar licencias del widget (generá uno aleatorio largo).
# Las licencias se emiten con: node scripts/generar-licencia.mjs "Marca" dominio
LICENCIA_SECRET=
