# ── Anthropic ────────────────────────────────────────────────────────────────
# Tu llave real: https://console.anthropic.com -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-tu-llave-aqui

# Opcional. Por defecto Haiku (rápido y económico). Alternativa: claude-sonnet-5
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Shopify Storefront API (opcional) ────────────────────────────────────────
# Si configurás esto, Silvi consulta productos y precios EN VIVO desde tu tienda.
# Si lo dejás vacío, usa los productos de ejemplo de lib/knowledge-base.ts.
#
# Dominio interno de tu tienda (NO el dominio personalizado):
SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
# Token PÚBLICO de Storefront API (solo lectura; seguro para producción):
SHOPIFY_STOREFRONT_TOKEN=tu-storefront-access-token
# Opcional. Versión estable de la API (por defecto 2026-04):
SHOPIFY_API_VERSION=2026-04
